<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:backgroundTint="#F9F8F8"
    tools:context=".registro_datosPersonales">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center|top"
        android:orientation="vertical">

        <EditText
            android:id="@+id/et_nombre"
            android:layout_width="350dp"
            android:layout_height="50dp"
            android:ems="10"
            android:fontFamily="@font/rem"
            android:hint="Nombre"
            android:inputType="text"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/et_apellido"
            android:layout_width="350dp"
            android:layout_height="50dp"
            android:layout_marginTop="35dp"
            android:ems="10"
            android:fontFamily="@font/rem"
            android:hint="Apellido"
            android:inputType="text"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinner_tipo"
                android:layout_width="199dp"
                android:layout_height="48dp"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/et_numero"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:ems="10"
                android:fontFamily="@font/rem"
                android:hint="Número"
                android:inputType="number"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/chk_apto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/rem"
                android:text="Apto físico"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/chk_socio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/rem"
                android:text="¿Es socio/a?"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:orientation="horizontal">


            <Button
                android:id="@+id/btnLimpiar"
                android:layout_width="156dp"
                android:layout_height="52dp"
                android:layout_marginRight="20dp"
                android:width="20dp"
                android:backgroundTint="@android:color/transparent"
                android:fontFamily="@font/rem_medium"
                android:text="LIMPIAR"
                android:textColor="#212121"
                android:textSize="14sp"
                app:cornerRadius="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnAuxRecuadro"
                app:layout_constraintVertical_bias="0.744"
                app:strokeColor="#212121"
                app:strokeWidth="1dp" />


            <Button
                android:id="@+id/btnContinuar"
                android:layout_width="167dp"
                android:layout_height="53dp"
                android:backgroundTint="#212121"
                android:fontFamily="@font/rem_medium"
                android:text="CONTINUAR"
                android:textSize="14sp"
                app:cornerRadius="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnAuxRecuadro"
                app:layout_constraintVertical_bias="0.738"
                app:strokeColor="#070707" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>