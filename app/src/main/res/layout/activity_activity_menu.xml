<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_menu">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_activity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#212121"
        android:minHeight="50dp"
        android:theme="?attr/actionButtonStyle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/img_volver_activity"
        android:layout_width="28dp"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_activity_menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_activity"
        app:srcCompat="@drawable/volver" />

    <TextView
        android:id="@+id/tv_admin_activity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/rem"
        android:text="Admin"
        android:textColor="#606060"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_activity" />

    <ImageView
        android:id="@+id/imageView_admin_activity"
        android:layout_width="12dp"
        android:layout_height="10dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_admin_activity"
        app:layout_constraintEnd_toStartOf="@+id/tv_admin_activity"
        app:layout_constraintTop_toTopOf="@+id/tv_admin_activity"
        app:srcCompat="@drawable/admin" />

    <TextView
        android:id="@+id/tv_activity_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:fontFamily="@font/rem_bold"
        android:text="Gestión de Actividades"
        android:textAlignment="center"
        android:textColor="#212121"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_activity" />

    <Button
        android:id="@+id/btn_registrar_actividad"
        android:layout_width="300dp"
        android:layout_height="56dp"
        android:layout_marginTop="80dp"
        android:backgroundTint="#212121"
        android:fontFamily="@font/rem"
        android:text="Registrar actividad"
        android:textSize="16sp"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_activity_menu"
        app:strokeColor="@color/black" />

    <Button
        android:id="@+id/btn_cobrar_actividad"
        android:layout_width="300dp"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#212121"
        android:fontFamily="@font/rem"
        android:text="Cobrar actividad"
        android:textSize="16sp"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_registrar_actividad"
        app:strokeColor="@color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>