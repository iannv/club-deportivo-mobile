<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".cobrar">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="412dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:background="#212121"
        android:minHeight="50dp"
        android:theme="?attr/actionButtonStyle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tv_admin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/rem"
        android:text="Admin"
        android:textColor="#606060"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="12dp"
        android:layout_height="10dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_menu"
        app:layout_constraintEnd_toStartOf="@+id/tv_admin"
        app:srcCompat="@drawable/admin" />

    <TextView
        android:id="@+id/tv_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:fontFamily="@font/rem_bold"
        android:text="Cobrar cuota \no actividad"
        android:textAlignment="center"
        android:textColor="#212121"
        android:textSize="34sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2" />

    <EditText
        android:id="@+id/tv_dniCampo"
        android:layout_width="225dp"
        android:layout_height="61dp"
        android:layout_marginStart="32dp"
        android:ems="10"
        android:inputType="text"
        android:text="20.200.200"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_dniLabel" />

    <TextView
        android:id="@+id/tv_dniLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="210dp"
        android:text="DNI"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2" />


    <EditText
        android:id="@+id/tv_montoCampo"
        android:layout_width="219dp"
        android:layout_height="66dp"
        android:layout_marginStart="32dp"
        android:ems="10"
        android:inputType="text"
        android:text="$2300"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_montoLabel" />

    <TextView
        android:id="@+id/tv_montoLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="22dp"
        android:text="MONTO"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_dniCampo" />

    <Button
        android:id="@+id/tv_btnBuscar"
        android:layout_width="156dp"
        android:layout_height="52dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="224dp"
        android:width="20dp"
        android:backgroundTint="@color/white"
        android:text="BUSCAR"
        android:textColor="#0B0A0A"
        app:cornerRadius="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_montoCampo"
        app:strokeColor="@color/black"
        app:strokeWidth="1dp" />

    <Button
        android:id="@+id/tv_btnCobrar"
        android:layout_width="167dp"
        android:layout_height="53dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="224dp"
        android:backgroundTint="@color/black"
        android:text="COBRAR"
        app:cornerRadius="0dp"
        app:layout_constraintStart_toEndOf="@+id/tv_btnBuscar"
        app:layout_constraintTop_toBottomOf="@+id/tv_montoCampo"
        app:strokeColor="#070707" />

</androidx.constraintlayout.widget.ConstraintLayout>