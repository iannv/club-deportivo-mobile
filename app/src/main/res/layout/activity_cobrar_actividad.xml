<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".cobrar_actividad">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_cobrar_actividad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#212121"
        android:minHeight="50dp"
        android:theme="?attr/actionButtonStyle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/img_volver_cobrar_actividad"
        android:layout_width="28dp"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_cobrar_actividad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_cobrar_actividad"
        app:srcCompat="@drawable/volver" />

    <TextView
        android:id="@+id/tv_admin_cobrar_actividad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/rem"
        android:text="Admin"
        android:textColor="#606060"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_cobrar_actividad" />

    <ImageView
        android:id="@+id/imageView_admin_cobrar_actividad"
        android:layout_width="12dp"
        android:layout_height="10dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_admin_cobrar_actividad"
        app:layout_constraintEnd_toStartOf="@+id/tv_admin_cobrar_actividad"
        app:layout_constraintTop_toTopOf="@+id/tv_admin_cobrar_actividad"
        app:srcCompat="@drawable/admin" />

    <TextView
        android:id="@+id/tv_cobrar_actividad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:fontFamily="@font/rem_bold"
        android:text="Cobrar Actividad"
        android:textAlignment="center"
        android:textColor="#212121"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_cobrar_actividad" />

    <EditText
        android:id="@+id/et_dni_cobrar_actividad"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/edit_text_border"
        android:ems="10"
        android:fontFamily="@font/rem"
        android:hint="DNI del cliente"
        android:inputType="number"
        android:textAlignment="center"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_cobrar_actividad" />

    <Spinner
        android:id="@+id/spinner_actividades"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/edit_text_border"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_dni_cobrar_actividad" />

    <TextView
        android:id="@+id/tv_info_cliente"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/rem"
        android:gravity="center"
        android:textColor="#212121"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinner_actividades" />

    <TextView
        android:id="@+id/tv_precio_actividad"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/rem_bold"
        android:gravity="center"
        android:textColor="#212121"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_info_cliente" />

    <Button
        android:id="@+id/btn_buscar_cliente_actividad"
        android:layout_width="168dp"
        android:layout_height="53dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#212121"
        android:fontFamily="@font/rem_medium"
        android:text="BUSCAR CLIENTE"
        android:textSize="12sp"
        app:cornerRadius="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_precio_actividad"
        app:strokeColor="#070707" />

    <Button
        android:id="@+id/btn_cobrar_actividad_final"
        android:layout_width="300dp"
        android:layout_height="53dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#4CAF50"
        android:fontFamily="@font/rem_medium"
        android:text="COBRAR ACTIVIDAD"
        android:textSize="14sp"
        android:visibility="gone"
        app:cornerRadius="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_buscar_cliente_actividad"
        app:strokeColor="#070707" />

    <TextView
        android:id="@+id/tv_mensaje_cobrar_actividad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/rem"
        android:textColor="#D64646"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_cobrar_actividad_final" />

</androidx.constraintlayout.widget.ConstraintLayout>